# Скопируйте в .env и заполните реальными значениями перед запуском на сервере.
# .env не попадает в git (см. .gitignore).

POSTGRES_PASSWORD=change_me_strong_password
REDIS_PASSWORD=change_me_strong_password
JWT_SECRET=change_me_random_32_plus_chars

# Публичный адрес сервера (IP VPS или домен), без протокола на бэкенде,
# с http:// на фронтенде.
CORS_ORIGIN=http://SERVER_IP:3000
NEXT_PUBLIC_API_URL=http://SERVER_IP:3001/api/v1
APP_BASE_URL=http://SERVER_IP:3000

# ЮKassa (https://yookassa.ru/developers/api) — без этих переменных
# биллинг отключён: чекаут вернёт 503, остальной API работает как обычно.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# SMTP для восстановления пароля — без них ссылка на сброс просто пишется
# в лог контейнера api-gateway (docker compose logs api-gateway), письмо не уходит.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Email поддержки, показывается пользователям в интерфейсе (не Telegram)
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.ru
