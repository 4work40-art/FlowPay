# Скопируйте в .env и заполните реальными значениями перед запуском на сервере.
# .env не попадает в git (см. .gitignore).

POSTGRES_PASSWORD=change_me_strong_password
REDIS_PASSWORD=change_me_strong_password
JWT_SECRET=change_me_random_32_plus_chars

# Публичный адрес сервера (IP VPS или домен), без протокола на бэкенде,
# с http:// на фронтенде.
CORS_ORIGIN=http://SERVER_IP:3000
NEXT_PUBLIC_API_URL=http://SERVER_IP:3001/api/v1
